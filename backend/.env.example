# Environment — EXAMPLE
# Copy this to .env and fill in your values

# Neon PostgreSQL connection string (get from https://neon.tech dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/manufacturing_dashboard?sslmode=require

# Groq API key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# CORS — add your Vercel frontend URL
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Environment
APP_ENV=production
